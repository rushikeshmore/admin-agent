# ===== Store Connection =====
# Your myshopify.com subdomain (e.g., my-store for my-store.myshopify.com)
SHOPIFY_STORE=

# ===== Auth Option 1: Custom App Token (simple, for personal use) =====
# From: Settings > Apps and sales channels > Develop apps > API credentials
# Prefix: shpat_
SHOPIFY_ACCESS_TOKEN=

# ===== Auth Option 2: OAuth Client Credentials (production, 2026+) =====
# From: Partners Dashboard > Apps > API access
# SHOPIFY_CLIENT_ID=
# SHOPIFY_CLIENT_SECRET=

# ===== Optional =====
# API version (defaults to 2026-04)
# SHOPIFY_API_VERSION=2026-04
# Set to 1 to enable cost debug headers
# SHOPIFY_DEBUG=0
